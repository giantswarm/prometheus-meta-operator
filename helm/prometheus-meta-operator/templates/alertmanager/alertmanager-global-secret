apiVersion: v1
kind: Secret
metadata:
  labels:
    {{- include "labels.common" . | nindent 4 }}
  name: alertmanager-global
  namespace: {{ include "resource.default.namespace" . }}
data:
  slackApiUrl: {{ .Values.alertmanager.slack.apiUrl | quote }}
  opsGenieApiUrl: {{ .Values.alertmanager.opsGenie.apiUrl | quote }}
  opsGenieApiKey: {{ .Values.alertmanager.opsGenie.apiKey | quote }}
